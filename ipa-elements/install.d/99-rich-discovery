#!/bin/bash

# This element adds automatic hardware discovery to the IPA-based live image.
# It installs a systemd service that runs on first boot and collects
# hardware information, then sends it to the bastion collector.

cat > /usr/local/bin/hardware-discovery << 'SCRIPT'
#!/bin/bash

echo "================================================================"
echo "=== Hardware Discovery Starting                              ==="
echo "================================================================"

set +e

WIPE_MODE="none"
CHAIN_MODE="no"

grep -q 'wipe=strong' /proc/cmdline && WIPE_MODE="strong"
grep -q 'chain=yes'   /proc/cmdline && CHAIN_MODE="yes"

echo ">>> Wipe mode : $WIPE_MODE"
echo ">>> Chain mode: $CHAIN_MODE"

# Get basic identifiers
MAC=$(cat /sys/class/net/*/address 2>/dev/null | grep -v '00:00:00:00:00:00' | head -1 | tr ':' '-')
[ -z "$MAC" ] && MAC=$(ip -o link show | awk '/link\/ether/ {print $2; exit}' | tr ':' '-')

IP=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4; exit}' | cut -d/ -f1)
TIMESTAMP=$(date -Iseconds)

SYSTEM_SERIAL=$(dmidecode -s system-serial-number 2>/dev/null || echo "unknown")
SYSTEM_PRODUCT=$(dmidecode -s system-product-name 2>/dev/null || echo "unknown")
SYSTEM_VERSION=$(dmidecode -s system-version 2>/dev/null || echo "unknown")
SYSTEM_SKU=$(dmidecode -s system-sku-number 2>/dev/null || echo "unknown")
SYSTEM_UUID=$(dmidecode -s system-uuid 2>/dev/null || echo "unknown")
CHASSIS_SERIAL=$(dmidecode -s chassis-serial-number 2>/dev/null || echo "unknown")
BASEBOARD_SERIAL=$(dmidecode -s baseboard-serial-number 2>/dev/null || echo "unknown")

BOOT_MODE=$([ -d /sys/firmware/efi ] && echo "UEFI" || echo "Legacy")

CPU_COUNT=$(lscpu | awk '/^CPU\(s\):/ {print $2}')
MEM_TOTAL=$(free -h | awk '/Mem:/ {print $2}')

DISK_CONTROLLERS=$(lspci -nn 2>/dev/null | grep -iE 'RAID|SATA|SCSI|NVMe|storage controller' | head -10 || echo "")

# ============================================================
# Enhanced Network Interface Collection + Boot Interface Detection
# ============================================================
NICS_DETAILED="[]"
BOOT_INTERFACE=""
DEFAULT_ROUTE_IFACE=$(ip route show default 2>/dev/null | awk '/dev/ {print $5; exit}')

for iface in $(ls /sys/class/net/ 2>/dev/null | grep -v lo); do
    MAC=$(cat /sys/class/net/"$iface"/address 2>/dev/null)
    SPEED=$(cat /sys/class/net/"$iface"/speed 2>/dev/null || echo "unknown")
    STATE=$(cat /sys/class/net/"$iface"/operstate 2>/dev/null || echo "unknown")
    DRIVER=$(ethtool -i "$iface" 2>/dev/null | awk '/driver:/ {print $2}')
    PCI_ADDR=$(ethtool -i "$iface" 2>/dev/null | awk '/bus-info:/ {print $2}')

    IS_BOOT="false"
    if [ "$iface" = "$DEFAULT_ROUTE_IFACE" ]; then
        IS_BOOT="true"
        BOOT_INTERFACE="$iface"
    fi

    NIC_OBJ=$(jq -n \
        --arg name "$iface" \
        --arg mac "$MAC" \
        --arg speed "$SPEED" \
        --arg state "$STATE" \
        --arg driver "${DRIVER:-unknown}" \
        --arg pci "${PCI_ADDR:-}" \
        --argjson is_boot "$IS_BOOT" \
        '{
            name: $name,
            mac: $mac,
            speed_mbps: $speed,
            state: $state,
            driver: $driver,
            pci_address: $pci,
            is_boot_interface: $is_boot
        }')

    NICS_DETAILED=$(echo "$NICS_DETAILED" | jq --argjson nic "$NIC_OBJ" '. + [$nic]')
done

BOOT_MAC=$(cat /sys/class/net/"$BOOT_INTERFACE"/address 2>/dev/null || echo "")

LLDP_INFO="{}"
if command -v lldpctl >/dev/null 2>&1; then
    LLDP_INFO=$(lldpctl -f json 2>/dev/null || echo '{}')
fi

# ============================================================
# Enhanced Disk Inventory for rootDeviceHints (OCP)
# ============================================================
DISKS_DETAILED="[]"

for disk in $(lsblk -dn -o NAME,TYPE 2>/dev/null | awk '$2=="disk" {print $1}'); do
    DEV="/dev/${disk}"

    BY_PATH=$(ls -1 /dev/disk/by-path/ 2>/dev/null | xargs -I{} sh -c 'readlink -f /dev/disk/by-path/{} | grep -q "'"$DEV"'" && echo "/dev/disk/by-path/{}"' | head -1 || echo "")
    BY_ID=$(ls -1 /dev/disk/by-id/ 2>/dev/null | xargs -I{} sh -c 'readlink -f /dev/disk/by-id/{} | grep -q "'"$DEV"'" && echo "/dev/disk/by-id/{}"' | head -1 || echo "")

    SIZE=$(lsblk -dn -o SIZE "$DEV" 2>/dev/null | tr -d ' ')
    MODEL=$(lsblk -dn -o MODEL "$DEV" 2>/dev/null | sed 's/^[ \t]*//;s/[ \t]*$//')
    VENDOR=$(lsblk -dn -o VENDOR "$DEV" 2>/dev/null | sed 's/^[ \t]*//;s/[ \t]*$//')
    SERIAL=$(lsblk -dn -o SERIAL "$DEV" 2>/dev/null | sed 's/^[ \t]*//;s/[ \t]*$//')
    WWN=$(lsblk -dn -o WWN "$DEV" 2>/dev/null | sed 's/^[ \t]*//;s/[ \t]*$//')
    TRAN=$(lsblk -dn -o TRAN "$DEV" 2>/dev/null | sed 's/^[ \t]*//;s/[ \t]*$//')

    ROTATIONAL=$(cat /sys/block/"$disk"/queue/rotational 2>/dev/null)
    case "$ROTATIONAL" in
        1) ROTATIONAL="true" ;;
        0) ROTATIONAL="false" ;;
        *) ROTATIONAL="unknown" ;;
    esac

    SIZE_GIB=$(lsblk -b -dn -o SIZE "$DEV" 2>/dev/null | awk '{printf "%.0f", $1/1024/1024/1024}')

    HCTL=""
    if [ -d /sys/block/"$disk"/device ]; then
        HCTL=$(cat /sys/block/"$disk"/device/hctl 2>/dev/null || echo "")
    fi

    DISK_OBJ=$(jq -n \
        --arg dev "$DEV" \
        --arg by_path "${BY_PATH:-}" \
        --arg by_id "${BY_ID:-}" \
        --arg model "${MODEL:-}" \
        --arg vendor "${VENDOR:-}" \
        --arg serial "${SERIAL:-}" \
        --arg wwn "${WWN:-}" \
        --arg transport "${TRAN:-}" \
        --argjson size_gib "${SIZE_GIB:-0}" \
        --argjson rotational "$ROTATIONAL" \
        --arg hctl "${HCTL:-}" \
        '{
            device: $dev,
            by_path: $by_path,
            by_id: $by_id,
            model: $model,
            vendor: $vendor,
            serial: $serial,
            wwn: $wwn,
            transport: $transport,
            size_gib: $size_gib,
            rotational: $rotational,
            hctl: $hctl
        }')

    DISKS_DETAILED=$(echo "$DISKS_DETAILED" | jq --argjson disk "$DISK_OBJ" '. + [$disk]')
done

if [ "$WIPE_MODE" = "strong" ]; then
    echo ">>> Performing strong disk wipe..."
    for disk in $(lsblk -dn -o NAME,TYPE 2>/dev/null | awk '$2=="disk"{print "/dev/"$1}'); do
        wipefs -a "$disk" >/dev/null 2>&1 || true
        sgdisk --zap-all "$disk" >/dev/null 2>&1 || true
        dd if=/dev/zero of="$disk" bs=1M count=1024 status=progress 2>/dev/null || true
        blkdiscard "$disk" >/dev/null 2>&1 || true
        sync
    done
    echo ">>> Strong wipe completed."
fi

cat > /var/tmp/hardware.json << JSON
{
  "mac": "${MAC}",
  "current_ip": "${IP}",
  "timestamp": "${TIMESTAMP}",
  "wipe_mode": "${WIPE_MODE}",
  "chain_mode": "${CHAIN_MODE}",
  "system": {
    "serial": "${SYSTEM_SERIAL}",
    "product": "${SYSTEM_PRODUCT}",
    "version": "${SYSTEM_VERSION}",
    "sku": "${SYSTEM_SKU}",
    "uuid": "${SYSTEM_UUID}",
    "chassis_serial": "${CHASSIS_SERIAL}",
    "baseboard_serial": "${BASEBOARD_SERIAL}",
    "boot_mode": "${BOOT_MODE}"
  },
  "cpu_count": "${CPU_COUNT}",
  "memory": "${MEM_TOTAL}",
  "disk_controllers": "${DISK_CONTROLLERS}",
  "boot_interface": "${BOOT_INTERFACE}",
  "boot_mac": "${BOOT_MAC}",
  "nics_detailed": ${NICS_DETAILED},
  "lldp_neighbors": ${LLDP_INFO},
  "disks_detailed": ${DISKS_DETAILED},
  "source": "rich-discovery-element"
}
JSON

echo ">>> Sending report to collector..."
curl -sS -X POST -H "Content-Type: application/json" \
     --data @/var/tmp/hardware.json \
     "http://192.168.1.185:5000/api/inventory" || echo "WARNING: Could not reach collector at this time"

echo ""
echo "================================================================"
if [ "$CHAIN_MODE" = "yes" ]; then
    echo ">>> DISCOVERY COMPLETE - CHAIN MODE"
    echo ">>> Report sent. Machine will stay up."
    echo ">>> JSON saved to: /var/tmp/hardware.json"
    echo "================================================================"
    echo ""
    echo ">>> Waiting for next instructions..."
    while true; do
        sleep 300
        echo "[$(date '+%H:%M:%S')] Still waiting..."
    done
else
    echo ">>> DISCOVERY COMPLETE"
    echo ">>> Rebooting in 10 seconds..."
    echo "================================================================"
    sleep 10
    reboot
fi
SCRIPT

chmod +x /usr/local/bin/hardware-discovery

cat > /etc/systemd/system/hardware-discovery.service << 'SERVICE'
[Unit]
Description=Hardware Discovery Collection
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/hardware-discovery
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
SERVICE

systemctl enable hardware-discovery.service

echo "=== rich-discovery element installed successfully ==="
