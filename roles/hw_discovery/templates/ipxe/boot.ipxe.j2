#!ipxe

set menu-timeout 30000
set menu-default discovery

menu iPXE Boot Menu - Hardware Discovery (Air-Gapped)

item discovery          Safe Discovery (No disk changes) [DEFAULT]
item discovery-wipe     **DESTRUCTIVE** Wipe + Discovery
item discovery-chain    Safe Discovery + Chain (stay up for next payload)
item discovery-wipe-chain **DESTRUCTIVE** Wipe + Discovery + Chain
item shell              iPXE Shell (for debugging)
item reboot             Reboot

choose --timeout \${menu-timeout} --default \${menu-default} selected || goto cancel

goto \${selected}

:discovery
    kernel http://192.168.1.185/fedora-live/vmlinuz
    initrd http://192.168.1.185/fedora-live/initrd.img
    boot || shell

:discovery-wipe
    kernel http://192.168.1.185/fedora-live/vmlinuz wipe=strong
    initrd http://192.168.1.185/fedora-live/initrd.img
    boot || shell

:discovery-chain
    echo Starting Safe Discovery in Chain Mode...
    kernel http://192.168.1.185/fedora-live/vmlinuz chain=yes
    initrd http://192.168.1.185/fedora-live/initrd.img
    boot || chain http://192.168.1.185/ipxe/next-payload.ipxe || shell

:discovery-wipe-chain
    echo Starting DESTRUCTIVE Discovery + Chain Mode...
    kernel http://192.168.1.185/fedora-live/vmlinuz wipe=strong chain=yes
    initrd http://192.168.1.185/fedora-live/initrd.img
    boot || chain http://192.168.1.185/ipxe/next-payload.ipxe || shell

:shell
    echo Dropping to iPXE shell...
    shell

:reboot
    reboot

:cancel
    echo Boot cancelled.
    shell
