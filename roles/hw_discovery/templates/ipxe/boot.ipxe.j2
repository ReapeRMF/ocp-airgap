#!ipxe

# iPXE boot menu for hardware discovery
# This menu is served over HTTP.
# Parameters such as chain=yes and wipe=strong are passed directly on the
# kernel line. This ensures they reliably appear in /proc/cmdline inside the live image.

set menu-timeout 30000
set menu-default discovery

menu iPXE Boot Menu - Hardware Discovery (Air-Gapped)

item --gap ---------------- System Information ----------------
item --gap Serial / Service Tag will appear after boot
item --gap ----------------------------------------------------
item discovery          Safe Discovery (No disk changes) [DEFAULT]
item discovery-wipe     ** DESTRUCTIVE ** Wipe + Discovery
item discovery-chain    Safe Discovery + Chain (stay up after collection)
item discovery-wipe-chain ** DESTRUCTIVE ** Wipe + Discovery + Chain
item shell              iPXE Shell (for debugging)
item reboot             Reboot

choose --timeout ${menu-timeout} --default ${menu-default} selected || goto cancel

goto ${selected}

:discovery
    kernel http://{{ bastion_ip }}/fedora-live/vmlinuz
    initrd http://{{ bastion_ip }}/fedora-live/initrd.img
    boot || shell

:discovery-wipe
    kernel http://{{ bastion_ip }}/fedora-live/vmlinuz wipe=strong
    initrd http://{{ bastion_ip }}/fedora-live/initrd.img
    boot || shell

:discovery-chain
    echo Starting Discovery in Chain Mode...
    kernel http://{{ bastion_ip }}/fedora-live/vmlinuz chain=yes
    initrd http://{{ bastion_ip }}/fedora-live/initrd.img
    boot || chain http://{{ bastion_ip }}/ipxe/next-payload.ipxe || shell

:discovery-wipe-chain
    echo Starting DESTRUCTIVE Discovery in Chain Mode...
    kernel http://{{ bastion_ip }}/fedora-live/vmlinuz wipe=strong chain=yes
    initrd http://{{ bastion_ip }}/fedora-live/initrd.img
    boot || chain http://{{ bastion_ip }}/ipxe/next-payload.ipxe || shell

:shell
    echo Dropping to iPXE shell for debugging...
    shell

:reboot
    reboot

:cancel
    echo Boot cancelled by user.
    shell
