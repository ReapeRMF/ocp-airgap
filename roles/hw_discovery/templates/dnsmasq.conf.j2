# dnsmasq configuration for PXE hardware discovery
# Managed by Ansible role hw_discovery

# Basic operation
no-resolv
bind-dynamic

# Listen only on the provisioning interface
interface={{ dhcp_interface }}

# DHCP range for new machines
dhcp-range={{ dhcp_range_start }},{{ dhcp_range_end }},{{ dhcp_lease_time }}

# TFTP settings
enable-tftp
tftp-root={{ pxe_tftp_root }}

# Logging for troubleshooting
log-dhcp
log-facility=local7

# Optional: tell clients the next server (this bastion)
# next-server is usually set by the DHCP server itself via the filename option below

# Default boot file for UEFI machines (can be overridden per host or tag)
# filename for legacy BIOS would be undionly.kpxe or pxelinux.0
# We primarily use iPXE chainloading now.
